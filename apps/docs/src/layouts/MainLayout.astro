---
// apps/docs/src/layouts/MainLayout.astro
import '../../../../packages/core/src/styles/tokens.css';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

const { title = "Celestia | Design Engineering" } = Astro.props;
---

<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-sans/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-mono/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;700&display=swap" rel="stylesheet">
    
    <script is:inline>
        // Lógica de tema imediata para evitar flash
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        })();
      
        if (theme === 'light') document.documentElement.classList.remove('dark');
        else document.documentElement.classList.add('dark');
        window.localStorage.setItem('theme', theme);
    </script>
    
    <title>{title}</title>
</head>
<body>
    <div class="app-shell">
        <TopNav />
        <Sidebar />
        <main class="main-content">
            <div class="content-wrapper">
                <slot />
            </div>
        </main>
        <Footer />
    </div>
</body>
</html>

<style is:global>
    :root {
        --nav-h: 64px;
        --foot-h: 40px;
        --side-w: 280px;
    }

    html, body {
        margin: 0; padding: 0;
        height: 100vh; width: 100vw;
        overflow: hidden; 
        background: var(--ce-bg-main, #050508);
        color: var(--ce-text-main, #f0f0f0);
        font-family: 'Geist Sans', sans-serif;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Tokens rápidos para Light Mode */
    html:not(.dark) {
        --ce-bg-main: #f9f9fb;
        --ce-text-main: #1a1a1e;
        --ce-cloud: #1a1a1e;
    }

    .app-shell {
        display: grid;
        grid-template-areas: 
            "header header"
            "sidebar main"
            "sidebar footer";
        grid-template-rows: var(--nav-h) 1fr var(--foot-h);
        grid-template-columns: var(--side-w) 1fr;
        height: 100vh;
        width: 100vw;
    }

    .main-content {
        grid-area: main;
        overflow-y: auto;
        padding: 4rem 10%;
        transition: filter 0.3s ease, opacity 0.3s ease;
    }

    .content-wrapper { max-width: 900px; margin: 0 auto; }

    @media (max-width: 1024px) {
        .app-shell {
            grid-template-areas: "header" "main" "footer";
            grid-template-columns: 1fr;
        }
        .sidebar { grid-area: auto; }
        body.menu-open .sidebar { transform: translateX(0); }
        body.menu-open .main-content { 
            filter: blur(12px); 
            opacity: 0.3; 
            pointer-events: none; 
        }
    }
</style>