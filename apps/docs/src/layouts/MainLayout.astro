---
/* apps/docs/src/layouts/MainLayout.astro */
import '../../../../packages/core/src/styles/index.css';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import celestiaLogo from '../assets/logo.svg?raw';

const { title = "Celestia DS", headings = [] } = Astro.props;
---

<!doctype html>
<html lang="pt-PT" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Geist:wght@100..900&family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
    <title>{title}</title>
</head>
<body>
    <header class="app-header">
        <TopNav />
    </header>
    
    <div class="app-body">
        <aside class="app-sidebar">
            <div class="sidebar-mobile-header">
                <div class="logo-wrapper">
                    <div class="logo-svg" set:html={celestiaLogo} />
                    <span class="logo-text">Celestia.</span>
                </div>
            </div>
            <Sidebar />
        </aside>
        
        <main class="app-content">
            <div class="scroll-area">
                <div class="content-wrapper">
                    <article class="content-container">
                        <slot />
                    </article>
                </div>
            </div>
            <div class="status-bar-wrapper">
                <Footer />
            </div>
        </main>

        {headings.length > 0 && (
            <aside class="app-toc">
                <TableOfContents headings={headings} />
            </aside>
        )}
    </div>
    <div id="sidebar-overlay" class="overlay"></div>
</body>
</html>

<script>
    const overlay = document.getElementById('sidebar-overlay');
    overlay?.addEventListener('click', () => {
        document.body.classList.remove('menu-open');
    });
</script>