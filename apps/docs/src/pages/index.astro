---
// src/pages/index.astro
const title = "Celestia | Design Engineering";
const slogan = "Where Logic Meets Aesthetics";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<style>
			body {
				background: #1a1b2e; /* Void */
				color: #f0f1f5;     /* Cloud */
				font-family: sans-serif;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100vh;
				margin: 0;
			}
			h1 {
				font-size: 3.5rem;
				background: linear-gradient(135deg, #00d4ff, #7c4dff);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin: 0;
			}
			p { font-style: italic; opacity: 0.7; font-size: 1.2rem; }
		</style>
	</head>
	<body>
		<h1>{title}</h1>
		<p>{slogan}</p>
		<div style="margin-top: 2rem; color: #00f5a0; font-family: monospace;">
			[ System Status: Online ]
		</div>
	</body>
</html>