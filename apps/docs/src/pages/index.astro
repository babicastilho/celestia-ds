---
// src/pages/index.astro
const title = "Celestia | Design Engineering";
const slogan = "Where Logic Meets Aesthetics";

import '../../../../packages/core/src/styles/tokens.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-sans/style.css">
		<title>{title}</title>
		<style>
			body {
				background: var(--ce-bg-main);
				color: var(--ce-text-main);
				font-family: var(--ce-font-sans);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100vh;
				margin: 0;
			}

			h1 {
        font-family: var(--ce-font-serif);
        font-size: 4rem;
        font-weight: 700;
				background: var(--ce-gradient-main);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin: 0;
				letter-spacing: -0.02em;
			}

			p { 
				font-style: italic; 
				opacity: 0.7; 
				font-size: 1.2rem; 
				margin-top: 0.5rem;
			}

			.status-container {
				margin-top: 2.5rem;
				padding: 0.5rem 1rem;
				border: 1px solid var(--ce-brand-500);
				border-radius: 4px;
				font-family: monospace;
				color: var(--ce-accent-500);
			}
		</style>
	</head>
	<body>
		<h1>{title}</h1>
		<p>{slogan}</p>
		
		<div class="status-container">
			[ System Status: Online ]
		</div>
	</body>
</html>