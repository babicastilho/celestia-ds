---
const { headings = [] } = Astro.props;
---

<nav class="toc-nav">
    <span class="toc-title">ON THIS PAGE</span>
    <ul>
        {headings.map(item => (
            <li>
                {item.isDivider ? (
                    <span class="toc-label">{item.text}</span>
                ) : (
                    <a href={`#${item.id}`} class="toc-link" data-id={item.id}>{item.text}</a>
                )}
            </li>
        ))}
    </ul>
</nav>

<script>
    // Selecionamos o container que faz o scroll real definido no MainLayout
    const scrollContainer = document.querySelector('.scroll-area') || document.querySelector('.scroll-container');
    
    const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            // Só ativa se o elemento estiver a entrar no topo do ecrã
            if (entry.isIntersecting) {
                const id = entry.target.getAttribute('id');
                const link = document.querySelector(`.toc-link[data-id="${id}"]`);
                
                if(link) {
                    document.querySelectorAll('.toc-link').forEach(l => l.classList.remove('active'));
                    link.classList.add('active');
                }
            }
        });
    }, { 
        root: scrollContainer, 
        rootMargin: '-10% 0px -80% 0px', // Focado na parte superior para precisão
        threshold: 0 
    });

    // Observa seções reais. O ID deve estar na section, não numa div vazia.
    document.querySelectorAll('section[id]').forEach(section => {
        observer.observe(section);
    });
</script>

<style>
    .toc-nav { position: sticky; top: 0; }
    .toc-title {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--ce-text-main);
        margin-bottom: 1rem;
        display: block;
        font-family: 'Geist Mono', monospace;
    }
    ul { list-style: none; padding: 0; margin: 0; border-left: 1px solid var(--ce-border); }
    
    .toc-link {
        display: block;
        padding: 0.4rem 0 0.4rem 1rem;
        font-size: 0.85rem;
        color: var(--ce-text-muted);
        text-decoration: none;
        border-left: 2px solid transparent;
        margin-left: -1px;
        transition: color 0.2s;
        font-family: 'Geist Sans', sans-serif;
    }

    .toc-label {
        display: block;
        padding: 1rem 0 0.4rem 1rem;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--ce-text-muted);
        text-transform: uppercase;
        font-family: 'Geist Mono', monospace;
        opacity: 0.5;
    }
    
    .toc-link:hover { color: var(--ce-text-main); border-left-color: var(--ce-text-muted); }
    .toc-link.active { color: var(--ce-brand-500); border-left-color: var(--ce-brand-500); font-weight: 600; }
</style>