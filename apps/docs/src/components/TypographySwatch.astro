---
import { Icon } from 'astro-icon/components';
const { family, weight, name } = Astro.props;
---
<div class="doc-item-card typography-item">
  <div class="preview" style={`font-family: var(${family}); font-weight: ${weight};`}>
    Aa
  </div>
  <div class="card-info">
    <span class="weight-badge">{name} {weight}</span>
    <div class="code-group">
      <div class="copy-row copy-trigger" data-copy={family} title="Clique para copiar">
        <span class="label">VAR:</span> 
        <div class="val-group">
          <code class="val">{family}</code>
          <Icon name="lucide:copy" class="copy-icon" />
        </div>
      </div>
      <div class="copy-row">
        <span class="label">WGT:</span> 
        <code class="val">{weight}</code>
      </div>
    </div>
  </div>
</div>

<style>
  .preview { 
    height: 120px; display: flex; align-items: center; justify-content: center; 
    font-size: 3.5rem; background: rgba(255,255,255,0.02);
    border-bottom: 1px solid var(--ce-border); color: var(--ce-text-main);
  }
  .card-info { padding: 1rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .weight-badge { font-family: "Geist Mono"; font-weight: bold; font-size: 0.9rem; color: var(--ce-text-main); }
  .code-group { display: flex; flex-direction: column; gap: 0.3rem; }
  .copy-row { 
    display: flex; justify-content: space-between; background: rgba(255,255,255,0.03); 
    padding: 5px 8px; border-radius: 4px; align-items: center; transition: 0.2s;
  }
  .copy-trigger { cursor: pointer; }
  .copy-trigger:hover { background: rgba(255, 255, 255, 0.08); }
  
  .val-group { display: flex; align-items: center; gap: 0.5rem; }
  .val { font-family: "Geist Mono"; font-size: 0.7rem; color: var(--ce-text-muted); }
  
  .copy-icon { font-size: 0.8rem; opacity: 0; transition: 0.2s; color: var(--ce-brand-500); }
  .copy-trigger:hover .copy-icon { opacity: 1; }
  .label { font-size: 0.6rem; font-weight: bold; color: var(--ce-text-muted); opacity: 0.5; width: 30px; }
</style>