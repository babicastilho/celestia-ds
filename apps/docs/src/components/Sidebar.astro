---
import { Icon } from 'astro-icon/components';
import { navigation } from '../config/navigation';

const pathname = new URL(Astro.request.url).pathname;

const visibleSections = navigation.filter((section) => section.items.length > 0);

const isItemActive = (href: string) =>
  pathname === href || (href !== '/' && pathname.startsWith(href + '/'));

const isSectionActive = (items: { href: string }[]) =>
  items.some((item) => isItemActive(item.href));
---

<aside class="sidebar-inner">
  <nav class="side-nav" id="accordion-nav">
    {visibleSections.map((section) => (
      <div class:list={['accordion-item', { 'is-active': isSectionActive(section.items) }]}>
        <button class="accordion-trigger">
          {section.title}
          <Icon name="lucide:chevron-down" class="chevron" />
        </button>

        <div class="accordion-content">
          {section.items.map((item) => (
            <a href={item.href} class={isItemActive(item.href) ? 'active' : ''}>
              {item.label}
            </a>
          ))}
        </div>
      </div>
    ))}
  </nav>

  <div class="sidebar-mobile-footer">
    <a href="/docs" class="footer-icon">
      <Icon name="lucide:book" />
    </a>
    <a href="/cookbook" class="footer-icon">
      <Icon name="lucide:shapes" />
    </a>
    <a href="https://github.com" target="_blank" class="footer-icon">
      <Icon name="lucide:github" />
    </a>
  </div>
</aside>

<script>
  const nav = document.getElementById('accordion-nav');

  nav?.querySelectorAll('.accordion-trigger').forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      const currentItem = e.currentTarget.closest('.accordion-item');
      if (!currentItem) return;

      const wasOpen = currentItem.classList.contains('is-active');

      nav.querySelectorAll('.accordion-item').forEach((item) => {
        item.classList.remove('is-active');
      });

      if (!wasOpen) currentItem.classList.add('is-active');
    });
  });
</script>