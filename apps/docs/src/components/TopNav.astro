---
// apps/docs/src/components/TopNav.astro
import { Icon } from 'astro-icon/components';
import celestiaLogo from '../assets/logo.svg?raw';
---
<header class="top-nav">
    <a href="/" class="brand-wrapper" aria-label="Celestia Home">
        
        <div class="logo-svg" set:html={celestiaLogo} />

        <div class="nav-brand">Celestia<span class="dot">.</span></div>
    </a>
    
    <div class="nav-right">
        <nav class="top-links">
            <a href="/" class="active">Docs</a>
            <a href="#">Cookbook</a>
            <a href="https://github.com/babicastilho/celestia-ds" target="_blank" class="icon-link" aria-label="GitHub">
                <span class="nav-icon-wrap"><Icon name="lucide:github" /></span>
            </a>
        </nav>

        <button id="theme-toggle" class="theme-btn" aria-label="Toggle Theme">
            <span class="sun-icon"><Icon name="lucide:sun" /></span>
            <span class="moon-icon"><Icon name="lucide:moon" /></span>
        </button>

        <button id="mobile-menu-btn" class="hamburger" aria-label="Toggle Menu">
            <span class="line"></span>
            <span class="line"></span>
            <span class="line"></span>
        </button>
    </div>
</header>

<script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    menuBtn?.addEventListener('click', () => document.body.classList.toggle('menu-open'));

    const themeBtn = document.getElementById('theme-toggle');
    themeBtn?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) {
            document.documentElement.classList.remove('dark');
            document.documentElement.setAttribute('data-theme', 'light');
            localStorage.setItem('theme', 'light');
        } else {
            document.documentElement.classList.add('dark');
            document.documentElement.setAttribute('data-theme', 'dark');
            localStorage.setItem('theme', 'dark');
        }
    });
</script>

<style>
    .top-nav {
        grid-area: header; 
        display: flex; 
        align-items: center; 
        justify-content: space-between;
        padding: 0 2rem; 
        
        background: var(--ce-bg-glass); 
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--ce-border);
        color: var(--ce-text-main);
        
        z-index: 100;
        transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    /* Wrapper da Marca */
    .brand-wrapper {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        text-decoration: none;
        color: inherit;
        transition: opacity 0.3s;
        height: 100%;
    }
    .brand-wrapper:hover { 
        opacity: 0.8; 
    }

    /* Contentor do SVG */
    .logo-svg {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    /* Garante que o SVG importado ocupa o espaço todo */
    .logo-svg :global(svg) {
        width: 100%;
        height: 100%;
    }

    /* Tipografia da Marca */
    .nav-brand { 
        font-family: 'Lora', serif; 
        font-weight: bold; 
        font-size: 1.5rem; 
        letter-spacing: -0.02em;
        position: relative;
        top: -1px;
    }
    .dot { 
        color: var(--ce-brand); 
    }

    /* Área Direita */
    .nav-right { 
        display: flex; 
        align-items: center; 
        gap: 1.2rem; 
    }

    /* Links de Navegação */
    .top-links { 
        display: flex; 
        align-items: center; 
        gap: 1.5rem; 
    }
    .top-links a { 
        text-decoration: none; 
        color: var(--ce-text-muted); 
        font-size: 0.85rem; 
        transition: 0.2s;
    }
    .top-links a:hover, .top-links a.active { 
        color: var(--ce-brand); 
        opacity: 1; 
    }
    
    /* Ícone GitHub */
    .icon-link { 
        display: flex; 
        align-items: center; 
        color: var(--ce-icon-main); 
        transition: 0.2s; 
    }
    .icon-link:hover { 
        color: var(--ce-brand); 
    }
    .nav-icon-wrap { 
        font-size: 1.2rem; 
        display: flex; 
    }

    /* Botão de Tema */
    .theme-btn { 
        background: none; 
        border: none; 
        cursor: pointer; 
        color: var(--ce-icon-main); 
        padding: 8px; 
        opacity: 0.8; 
        transition: 0.2s; 
    }
    .theme-btn:hover { 
        opacity: 1; 
        color: var(--ce-brand); 
    }

    /* Ícones Sol/Lua */
    .sun-icon, .moon-icon { 
        font-size: 1.2rem; 
        display: flex; 
    }
    .moon-icon { display: none; }
    .sun-icon { display: block; }
    
    :global(.dark) .sun-icon { display: none; }
    :global(.dark) .moon-icon { display: block; }
    :global(html[data-theme='light']) .sun-icon { display: block; }
    :global(html[data-theme='light']) .moon-icon { display: none; }

    /* Hambúrguer Mobile */
    .hamburger { 
        display: none; 
        background: none; 
        border: none; 
        cursor: pointer; 
        flex-direction: column; 
        gap: 5px; 
        z-index: 110; 
        padding: 5px; 
    }
    .line { 
        width: 22px; 
        height: 2px; 
        background: var(--ce-icon-main); 
        transition: 0.3s; 
        border-radius: 2px; 
    }
    
    /* Animação do Hambúrguer */
    :global(body.menu-open) .line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    :global(body.menu-open) .line:nth-child(2) { opacity: 0; }
    :global(body.menu-open) .line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    @media (max-width: 1024px) { 
        .hamburger { display: flex; } 
        .top-links { display: none; } 
    }
</style>