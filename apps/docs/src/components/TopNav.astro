---
import { Icon } from "astro-icon/components";
import celestiaLogo from "../assets/logo.svg?raw";
---

<header class="top-nav">
  <div class="nav-left">
    <a href="/" class="logo-wrapper">
      <div class="logo-svg" set:html={celestiaLogo} />
      <span class="logo-text">Celestia<span class="dot">.</span></span>
    </a>
  </div>
  <div class="nav-right">
    <nav class="desktop-links">
      <a href="/docs">Docs</a>
      <a href="/cookbook">Cookbook</a>
    </nav>
    <div class="separator desktop-only"></div>
    <div class="actions-group">
      <a href="https://github.com" target="_blank" class="icon-btn desktop-only"
        ><Icon name="lucide:github" /></a
      >
      <button id="theme-toggle" class="icon-btn theme-toggle">
        <Icon name="lucide:sun" class="sun" />
        <Icon name="lucide:moon" class="moon" />
      </button
      >
      <button id="mobile-menu-btn" class="menu-btn mobile-only"
        ><div class="icon-stack">
          <Icon name="lucide:menu" class="icon-menu" />
          <Icon name="lucide:x" class="icon-close" />
        </div></button
      >
    </div>
  </div>
</header>
<script>
  document
    .getElementById("mobile-menu-btn")
    ?.addEventListener("click", () =>
      document.body.classList.toggle("menu-open"),
    );
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem(
      "celestia-theme-config",
      JSON.stringify({ theme: isDark ? "dark" : "light" }),
    );
  });
</script>
